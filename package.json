{
  "name": "stremio-shell-tv",
  "private": true,
  "version": "0.1.0",
  "description": "Android/Google TV shell for stremio-core in a dedicated TV-focused repo.",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test:contracts": "pnpm --filter @stremio-shell/core-bridge build && node --test \"packages/core-bridge/test/*.test.mjs\"",
    "test:tv-smoke": "pnpm --filter @stremio-shell/web test:tv-smoke",
    "test:web": "pnpm --filter @stremio-shell/web test",
    "upstream:sync": "node scripts/sync-upstream-stremio-web.mjs",
    "android:web-build": "pnpm --filter @stremio-shell/web build",
    "android:tv:assemble": "node scripts/run-gradle.mjs :app:assembleTvDebug",
    "android:tv:test": "node scripts/run-gradle.mjs :app:testTvDebugUnitTest",
    "core:use-npm": "pnpm --filter @stremio-shell/core-bridge add @stremio/stremio-core-web@0.52.0",
    "core:use-local": "node scripts/use-local-core.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  }
}
